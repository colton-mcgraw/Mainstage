{
    "version": "0.1.0",
    "description": "Declarative build and automation language",
    "homepage": "https://github.com/colton-mcgraw/mainstage",
    "license": "https://github.com/colton-mcgraw/mainstage/blob/main/LICENSE.md",
    "architecture": {
        "64bit": {
            "url": "https://github.com/colton-mcgraw/mainstage/releases/download/v0.1.0/mainstage-v0.1.0-x86_64-pc-windows-msvc.zip",
            "hash": "REPLACE_WITH_SHA256_X86_64_WINDOWS_MSVC",
            "extract_dir": "mainstage-v0.1.0-x86_64-pc-windows-msvc"
        }
    },
    "bin": [
        "mainstage.exe",
        "mainstage-lsp.exe"
    ],
    "checkver": {
        "github": "https://github.com/colton-mcgraw/mainstage"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/colton-mcgraw/mainstage/releases/download/v$version/mainstage-v$version-x86_64-pc-windows-msvc.zip",
                "extract_dir": "mainstage-v$version-x86_64-pc-windows-msvc"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
